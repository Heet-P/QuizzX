# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ── Neon Postgres ────────────────────────────────────────────────────────────
# Pooled connection (used by the app at runtime, via the Neon driver adapter).
# Neon dashboard → Connection Details → "Pooled connection".
DATABASE_URL=
# Direct/unpooled connection (used by `prisma migrate` — advisory locks needed
# for migrations aren't supported over Neon's pooled connection).
# Neon dashboard → Connection Details → "Direct connection".
DIRECT_URL=

# ── Clerk ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_dmVyaWZpZWQtZHJha2UtNzQuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_lOWkEBnfs8Z0UL1jdU13D2iDZNdAtYxlYCGCI7SGr1
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Comma-separated emails auto-promoted to role='admin' on first sign-in.
ADMIN_EMAILS=heet16@gmail.com

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Used to persist the original uploaded quiz document (.docx/.txt/.md) that the
# old app parsed in-memory and discarded. See MIGRATION_AUDIT.md Section 0.2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quizzx-uploads
# R2's S3-compatible endpoint is https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# — set explicitly here only if you need to override that default.
R2_PUBLIC_URL=

# ── AI features (quiz explanations, AI-authored quizzes, daily challenge) ───
NVIDIA_NIM_API_KEY=nvapi-...
GROQ_API_KEY=gsk_...

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Only needed if running more than one app instance and you want a shared
# cache / SSE fan-out across instances. Falls back to in-memory/local-only
# when unset — safe to leave blank for local dev and single-instance deploys.
REDIS_URL=

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
